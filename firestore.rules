rules_version = '2';

// ⚠️ Reglas abiertas: cualquiera con tu configuración de Firebase (que viaja
// en el código del sitio, es pública por diseño) puede leer y escribir estos
// datos directamente, sin pasar por los formularios de la app. Esto incluye
// los números de teléfono de las personas reportadas. Es el mismo nivel de
// protección que tenía la versión anterior (almacenamiento de artifact).
// Para más seguridad real, agregá Firebase Authentication y restringí estas
// reglas a usuarios autenticados. Ver README.md.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
